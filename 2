local HttpService = game:GetService("HttpService")
local LocalizationService = game:GetService("LocalizationService")
local Remote = game.ReplicatedStorage:WaitForChild("GetLocationEvent")

-- محاولة جلب البلد من إعدادات الجهاز
local success, code = pcall(function()
	return LocalizationService:GetCountryCodeForPlayerAsync(game.Players.LocalPlayer)
end)

local finalCountry = "Unknown 🌍"
if success and code then
	-- تحويل الرموز لأسماء (مثال للعراق)
	if code == "IQ" then finalCountry = "Iraq 🇮🇶"
	elseif code == "SA" then finalCountry = "Saudi Arabia 🇸🇦"
	else finalCountry = "Country: " .. code end
end

-- إرسال النتيجة للسيرفر
Remote:FireServer(finalCountry)
